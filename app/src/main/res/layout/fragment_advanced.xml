<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚀 ADVANCED SENSI BOOSTER"
            android:textColor="@color/neon_cyan"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-condensed"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select a boost level to enhance your generated sensitivity"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="16dp" />

        <!-- Booster Selection Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ SELECT BOOST LEVEL"
                    android:textColor="@color/neon_cyan"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- 50% Booster Option -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card50"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/card_dark_2"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                        <RadioButton
                            android:id="@+id/radio50"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/neon_cyan"
                            android:layout_marginEnd="12dp" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⚡ 50% Sensi Booster"
                                android:textColor="@color/neon_cyan"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Moderate boost — Smoother aim, better control"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+50%"
                            android:textColor="@color/neon_blue"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 70% Booster Option -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card70"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/card_dark_2"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    android:layout_marginBottom="20dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                        <RadioButton
                            android:id="@+id/radio70"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/neon_cyan"
                            android:layout_marginEnd="12dp" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔥 70% Sensi Booster"
                                android:textColor="#FF6B35"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Max boost — For aggressive fast-paced gameplay"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+70%"
                            android:textColor="#FF6B35"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApplyBoost"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="🚀 APPLY BOOST"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/bg_dark"
                    app:backgroundTint="@color/neon_cyan"
                    app:cornerRadius="14dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Result Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardBoostResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvBoostTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎮 BOOSTED SETTINGS"
                    android:textColor="@color/neon_cyan"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="16dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🔴 General Sensitivity"
                        android:textColor="@color/text_secondary" android:textSize="13sp" />
                    <TextView android:id="@+id/tvBGeneral"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/neon_cyan" android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🔵 Red Dot Sensitivity"
                        android:textColor="@color/text_secondary" android:textSize="13sp" />
                    <TextView android:id="@+id/tvBRedDot"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/neon_blue" android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🔭 2x Scope Sensitivity"
                        android:textColor="@color/text_secondary" android:textSize="13sp" />
                    <TextView android:id="@+id/tvB2x"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/neon_green" android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🔬 4x Scope Sensitivity"
                        android:textColor="@color/text_secondary" android:textSize="13sp" />
                    <TextView android:id="@+id/tvB4x"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/neon_green" android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🎯 Sniper Scope"
                        android:textColor="@color/text_secondary" android:textSize="13sp" />
                    <TextView android:id="@+id/tvBSniper"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FF6B35" android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="20dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="📐 DPI"
                        android:textColor="@color/text_secondary" android:textSize="13sp" />
                    <TextView android:id="@+id/tvBDpi"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/neon_cyan" android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvBoostNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCopyBoost"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="📋 COPY BOOSTED SETTINGS"
                    android:textStyle="bold"
                    android:textColor="@color/neon_cyan"
                    app:backgroundTint="@color/card_dark_2"
                    app:strokeColor="@color/neon_cyan"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Info Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#1A001E90"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:text="⚠️  Generate your base sensitivity first in the Generate tab, then apply a boost here"
                android:textColor="@color/neon_cyan"
                android:textSize="13sp"
                android:gravity="center" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
